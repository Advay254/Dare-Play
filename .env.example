# ─────────────────────────────────────────────
#  Dare Play — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your .env file.
# ─────────────────────────────────────────────

# Metered.ca TURN server credentials (used for WebRTC relay)
# Sign up free at: https://www.metered.ca
# Dashboard → TURN → your app → API Key
METERED_APP_NAME=your-app-name-here
METERED_API_KEY=your-metered-api-key-here

# Server port (optional — defaults to 3000)
PORT=3000
